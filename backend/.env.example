# Example environment variables for backend
# Copy this to backend/.env and fill values for your environment

# For PostgreSQL (production or remote DB):
# DATABASE_URL=postgresql://username:password@host:5432/dbname

# For local development without Postgres, leave DATABASE_URL empty to use SQLite dev.db
# ANTHROPIC API key for Claude (required to generate real AI roadmaps)
# Replace the placeholder below with your real key in your local `backend/.env`.
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
